generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  saveSlots   SaveSlot[]
  characters  Character[]
  runs        Run[]
}

model SaveSlot {
  id          String    @id @default(uuid())
  userId      String
  slotIndex   Int       // 1, 2, or 3
  characterId String?
  runId       String?
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  run       Run?       @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([userId, slotIndex])
}

model Character {
  id          String   @id @default(uuid())
  userId      String
  name        String
  species     String   // HUMAN, DWARF, ELF, MAGE
  level       Int      @default(1)
  xp          Int      @default(0)
  baseAttack  Int      @default(0)
  baseDefense Int      @default(0)
  baseLuck    Int      @default(0)
  baseHpMax   Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  saveSlots      SaveSlot[]
  runs           Run[]
  characterStats CharacterStats?
}

enum RunStatus {
  ACTIVE
  OVER
}

model Run {
  id           String    @id @default(uuid())
  userId       String
  characterId  String
  seed         Int
  fightCounter Int       @default(0)
  turnCounter  Int       @default(0)
  hp           Int
  coins        Int       @default(0)
  lastOutcome  String    @default("NONE")
  status       RunStatus @default(ACTIVE)
  stateJson    Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  character         Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)
  saveSlots         SaveSlot[]
  runInventoryItems RunInventoryItem[]
  runEquipment      RunEquipment?
}

model CharacterStats {
  id               String   @id @default(uuid())
  characterId      String   @unique
  totalKills       Int      @default(0)
  totalFights      Int      @default(0)
  wins             Int      @default(0)
  losses           Int      @default(0)
  retreats         Int      @default(0)
  totalCoinsEarned Int      @default(0)
  enemiesBySpecies Json     @default("{}")
  lastFightSummary Json?
  updatedAt        DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

enum ItemType {
  WEAPON
  ARMOR
  POTION
}

model ItemCatalog {
  id              String   @id @default(uuid())
  name            String   @unique
  itemType        ItemType
  attackBonus     Int      @default(0)
  defenseBonus    Int      @default(0)
  healPercent     Int      @default(25)
  sellValueCoins  Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  runInventoryItems RunInventoryItem[]
}

model RunInventoryItem {
  id             String   @id @default(uuid())
  runId          String
  itemCatalogId  String
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())

  run            Run              @relation(fields: [runId], references: [id], onDelete: Cascade)
  itemCatalog    ItemCatalog      @relation(fields: [itemCatalogId], references: [id], onDelete: Cascade)
  runEquipmentAsWeapon RunEquipment[] @relation("WeaponItem")
  runEquipmentAsArmor  RunEquipment[] @relation("ArmorItem")
}

model RunEquipment {
  runId                   String   @id
  weaponInventoryItemId   String?
  armorInventoryItemId    String?
  updatedAt               DateTime @updatedAt

  run                    Run                 @relation(fields: [runId], references: [id], onDelete: Cascade)
  weaponInventoryItem    RunInventoryItem?   @relation("WeaponItem", fields: [weaponInventoryItemId], references: [id], onDelete: SetNull)
  armorInventoryItem     RunInventoryItem?   @relation("ArmorItem", fields: [armorInventoryItemId], references: [id], onDelete: SetNull)
}
